# ── DeepSeek API (text generation) ────────────────────────────────────────────
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ── Together AI (image generation — FLUX.1-schnell-Free, free tier) ───────────
TOGETHER_API_KEY=your_together_api_key_here

# ── Supra RPC node ─────────────────────────────────────────────────────────────
# Mainnet (default):  https://rpc-mainnet.supra.com
# Testnet:            https://rpc-testnet.supra.com
SUPRA_RPC_URL=https://rpc-mainnet.supra.com

# ── Wallet balance mode ─────────────────────────────────────────────────────────
# Set to "true" for local dev — enables a /api/wallet/topup endpoint that adds
# balance without any real transaction (never use in production).
# When absent or "false", GET /api/wallet reads the user's REAL on-chain balance
# directly from the Supra blockchain every time the dashboard loads.
ALLOW_SIMULATED_TOPUP=false

# ── Real deposit collection ────────────────────────────────────────────────────
# Your Supra wallet address that receives real SUPRA payments from users.
# When set, the server polls this address every 20s and credits matching
# incoming payments to the right user's balance automatically.
# Leave unset to disable real deposits (you can still use ALLOW_SIMULATED_TOPUP).
SUPRA_DEPOSIT_ADDRESS=your_supra_wallet_address_here

# ── JWT secret ────────────────────────────────────────────────────────────────
# Change this to a long random string in production. Secrets the session tokens.
# Example: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
