# ── DeepSeek API ──────────────────────────────
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ── Telegram Bot (optional — fallback only) ───
# Channel credentials (Telegram, Discord, X/Twitter, Instagram) are
# now configured from the dashboard's "Channels" tab and stored in
# backend/data/db.json, so you can manage them without redeploying.
# These two are kept only as a first-run fallback for Telegram: if set
# here and the dashboard hasn't been touched yet, they're used to
# auto-enable the Telegram channel once.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Server ────────────────────────────────────
PORT=3001
