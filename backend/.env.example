# ── DeepSeek API (text generation) ────────────────────────────────────
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ── Together AI (image generation — FLUX.1-schnell-Free) ──────────────
# Free tier available at https://api.together.ai — create account, copy key.
# Without this key, image generation is skipped (posts still work normally).
TOGETHER_API_KEY=your_together_api_key_here

# ── Telegram Bot (optional env fallback) ──────────────────────────────
# Channels are primarily configured from the dashboard → Channels tab.
# These two are a first-run convenience seed for Telegram only.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Instagram (only needed if using a public server) ──────────────────
# For Instagram image posting to work, SupraPost must be publicly accessible.
# Set this to your public URL so Instagram can fetch the image files.
# IMAGE_BASE_URL=https://yourdomain.com

# ── Server ────────────────────────────────────────────────────────────
PORT=3001
