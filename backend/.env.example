# ── Auth ───────────────────────────────────────
# Secret used to sign wallet-login session tokens (JWT). Generate a real
# random value for production, e.g.: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string

# ── DeepSeek API ──────────────────────────────
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ── Telegram Bot (fallback / dev only) ────────
# In production, each user pastes their own bot token + chat id into the
# Setup > Channels card in the dashboard — these are stored per-wallet in
# data/db.json, not here. These env vars only act as a fallback default
# for local single-user testing.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Twitter / X (not implemented yet) ─────────
# Will use per-user OAuth 2.0 tokens stored in the database once wired up
# — no env vars needed here long-term.

# ── Instagram (not implemented yet) ───────────
# Same as Twitter — per-user tokens via the Instagram Graph API / Facebook Login.

# ── Discord (not implemented yet) ─────────────
# Per-user webhook URL, pasted directly by each user (no OAuth needed for webhooks).

# ── Payments (non-custodial SUPRA deposits) ───
# Your own wallet address that receives top-ups. Users sign a real
# transaction from their own wallet to send SUPRA here — you never hold
# their private keys, only this receiving address.
SUPRA_DEPOSIT_ADDRESS=

# Optional override if you're on mainnet instead of testnet
# SUPRA_RPC_URL=https://rpc-mainnet.supra.com

# Set to "true" ONLY for local development — lets you give yourself free
# simulated SUPRA balance via the dashboard's "+10 SUPRA" button, with no
# real transaction. Never enable this in production.
ALLOW_SIMULATED_TOPUP=true

# ── Server ────────────────────────────────────
PORT=3001
